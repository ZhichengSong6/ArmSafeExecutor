<launch>
    <!-- ======================== Gazebo options ======================== -->
    <arg name="use_gazebo" default="true" />
    <arg name="gazebo_gui" default="true" />
    <arg name="gazebo_paused" default="false" />
    <arg name="world_name" default="$(find arm_sim_node)/worlds/maixsense_empty.world" />

    <!-- ========================== RViz options ======================== -->
    <arg name="use_rviz" default="true" />
    <arg name="rviz_config" default="$(find arm_sim_node)/rviz/arm.rviz" />

    <!-- ========================== Spawn pose ========================== -->
    <arg name="spawn_x" default="0.0" />
    <arg name="spawn_y" default="0.0" />
    <arg name="spawn_z" default="0.0" />
    <arg name="spawn_roll" default="0.0" />
    <arg name="spawn_pitch" default="0.0" />
    <arg name="spawn_yaw" default="0.0" />

    <!-- ======================= Execution interface ==================== -->
    <!-- Final command after safety filtering. -->
    <arg name="command_topic" default="/arm_controller/joint_ref" />

    <!-- ======================= Robot description ====================== -->
    <param name="/use_sim_time" value="$(arg use_gazebo)" />

    <param name="robot_description"
           textfile="$(find arm_sim_node)/urdf/Arm.urdf" />

    <!-- ============================= Gazebo =========================== -->
    <group if="$(arg use_gazebo)">
        <include file="$(find gazebo_ros)/launch/empty_world.launch">
            <arg name="world_name" value="$(arg world_name)" />
            <arg name="paused" value="$(arg gazebo_paused)" />
            <arg name="use_sim_time" value="true" />
            <arg name="gui" value="$(arg gazebo_gui)" />
            <arg name="headless" value="false" />
            <arg name="debug" value="false" />
        </include>

        <node pkg="gazebo_ros"
              type="spawn_model"
              name="spawn_arm_in_gazebo"
              output="screen"
              args="-urdf -param robot_description -model Arm
                    -x $(arg spawn_x) -y $(arg spawn_y) -z $(arg spawn_z)
                    -R $(arg spawn_roll) -P $(arg spawn_pitch) -Y $(arg spawn_yaw)" />
    </group>

    <!-- ===================== Robot state publisher ==================== -->
    <node pkg="robot_state_publisher"
          type="robot_state_publisher"
          name="robot_state_publisher"
          output="screen" />

    <!-- ================== Simulation execution backend ================ -->
    <!--
        arm_sim_node only executes the final JointReference command,
        publishes /joint_states, and synchronizes the robot pose into
        Gazebo for RGB-D / point-cloud rendering.

        It does not generate target-tracking commands and does not
        perform safety filtering.
    -->
    <node pkg="arm_sim_node"
          type="arm_sim_node"
          name="arm_sim_node"
          output="screen">

        <param name="robot_description_param" value="/robot_description" />

        <param name="joint_states_topic" value="/joint_states" />
        <param name="command_topic" value="$(arg command_topic)" />

        <param name="publish_rate" value="100.0" />
        <param name="kp" value="5.0" />
        <param name="default_velocity_limit" value="0.5" />

        <param name="command_timeout" value="0.5" />
        <param name="use_command_gains" value="false" />
        <param name="command_kp_scale" value="1.0" />
        <param name="max_tracking_kp" value="20.0" />

        <!-- Kinematic synchronization into Gazebo for sensor rendering. -->
        <param name="sync_to_gazebo" value="$(arg use_gazebo)" />
        <param name="gazebo_model_name" value="Arm" />
        <param name="gazebo_urdf_param_name" value="robot_description" />
        <param name="gazebo_set_configuration_service"
               value="/gazebo/set_model_configuration" />
        <param name="gazebo_sync_rate" value="50.0" />

        <rosparam param="joint_names">
            - joint1
            - joint2
            - joint3
            - joint4
            - wrist_joint1
            - wrist_joint2
            - wrist_joint3
        </rosparam>

        <rosparam param="initial_positions">
            joint1: 0.0
            joint2: 0.0
            joint3: 0.0
            joint4: 0.0
            wrist_joint1: 0.0
            wrist_joint2: 0.0
            wrist_joint3: 0.0
        </rosparam>
    </node>

    <!-- ============================== RViz ============================ -->
    <group if="$(arg use_rviz)">
        <node pkg="rviz"
              type="rviz"
              name="rviz"
              args="-d $(arg rviz_config)"
              output="screen" />
    </group>
</launch>
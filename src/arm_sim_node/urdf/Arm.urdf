  <!-- Gazebo rendering frames and MaixSense prototype sensors on link4.
       Existing camera/tof links are ROS optical frames: x image-right,
       y image-down, z viewing-forward. Gazebo rendering cameras view
       along positive x, so dedicated gz links supply the fixed rotation. -->

  <!-- link4_sensor1 rendering frames -->
  <link name="link4_sensor1_camera_gz_link">
    <!-- Massless links are removed during URDF-to-SDF conversion when the
         fixed joint is preserved. This tiny positive inertia keeps the
         dedicated Gazebo rendering frame and its attached sensor in SDF. -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.000001" />
      <inertia
        ixx="0.000000001"
        ixy="0"
        ixz="0"
        iyy="0.000000001"
        iyz="0"
        izz="0.000000001" />
    </inertial>
  </link>
  <joint name="link4_sensor1_camera_gz_joint" type="fixed">
    <origin xyz="0 0 0" rpy="1.5707963267949 -1.5707963267949 0" />
    <parent link="link4_sensor1_camera_link" />
    <child link="link4_sensor1_camera_gz_link" />
    <axis xyz="0 0 0" />
  </joint>

  <link name="link4_sensor1_tof_gz_link">
    <!-- Massless links are removed during URDF-to-SDF conversion when the
         fixed joint is preserved. This tiny positive inertia keeps the
         dedicated Gazebo rendering frame and its attached sensor in SDF. -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.000001" />
      <inertia
        ixx="0.000000001"
        ixy="0"
        ixz="0"
        iyy="0.000000001"
        iyz="0"
        izz="0.000000001" />
    </inertial>
  </link>
  <joint name="link4_sensor1_tof_gz_joint" type="fixed">
    <origin xyz="0 0 0" rpy="1.5707963267949 -1.5707963267949 0" />
    <parent link="link4_sensor1_tof_link" />
    <child link="link4_sensor1_tof_gz_link" />
    <axis xyz="0 0 0" />
  </joint>

  <!-- link4_sensor2 rendering frames -->
  <link name="link4_sensor2_camera_gz_link">
    <!-- Massless links are removed during URDF-to-SDF conversion when the
         fixed joint is preserved. This tiny positive inertia keeps the
         dedicated Gazebo rendering frame and its attached sensor in SDF. -->
    <inertial>

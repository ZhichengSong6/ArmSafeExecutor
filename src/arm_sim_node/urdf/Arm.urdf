  <link name="link4_sensor2_tof_gz_link">
    <!-- Massless links are removed during URDF-to-SDF conversion when the
         fixed joint is preserved. This tiny positive inertia keeps the
         dedicated Gazebo rendering frame and its attached sensor in SDF. -->
    <inertial>

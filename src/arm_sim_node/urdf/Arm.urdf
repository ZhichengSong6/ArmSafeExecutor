  <!-- Preserve the explicit Gazebo rendering-frame joints for inspection. -->
  <gazebo reference="link4_sensor1_camera_gz_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="link4_sensor1_tof_gz_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

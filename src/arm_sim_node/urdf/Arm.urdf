  <!-- link4_sensor1 RGB: ideal RGB observation only -->
  <gazebo reference="link4_sensor1_camera_gz_link">
    <sensor type="camera" name="link4_sensor1_rgb_sensor">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>
      <camera name="link4_sensor1_rgb_camera">
        <horizontal_fov>2.0943951023932</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
      </camera>
      <plugin name="link4_sensor1_rgb_ros_plugin" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>link4_sensor1_rgb</cameraName>
        <imageTopicName>/link4_sensor1/rgb/image_raw</imageTopicName>
        <cameraInfoTopicName>/link4_sensor1/rgb/camera_info</cameraInfoTopicName>
        <frameName>link4_sensor1_camera_link</frameName>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <!-- link4_sensor1 ToF approximation: ideal depth plus PointCloud2 -->
  <gazebo reference="link4_sensor1_tof_gz_link">
    <sensor type="depth" name="link4_sensor1_tof_sensor">
      <always_on>true</always_on>
